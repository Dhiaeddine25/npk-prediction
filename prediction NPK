{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":14608299,"datasetId":9331094,"databundleVersionId":15444458}],"dockerImageVersionId":31287,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# ====================================================\n# DERNIГ€RE TENTATIVE : SPГ‰CIALISATION SUR LES LABELS FAIBLES\n# ====================================================\n\nimport os, json, time, gc\nimport numpy as np\nimport pandas as pd\nimport tensorflow as tf\nfrom tensorflow.keras import layers, optimizers, callbacks\nfrom sklearn.metrics import accuracy_score, f1_score\nfrom sklearn.utils.class_weight import compute_class_weight\n\nos.environ[\"CUDA_VISIBLE_DEVICES\"] = \"0\"\nprint(\"GPU :\", tf.config.list_physical_devices(\"GPU\"))\n\n# -----------------------------\n# CONFIGURATION\n# -----------------------------\nDATA_PATH = \"/kaggle/input/datasets/dhiaeddinesaadallah/prdiction-npk\"\nSAVE_DIR  = \"/kaggle/working/npk_ensemble_v3\"\nos.makedirs(SAVE_DIR, exist_ok=True)\n\n# ParamГЁtres plus agressifs pour les labels faibles\nIMG_SIZE = 224\nBATCH_SIZE = 16\nEPOCHS_PHASE1 = 15\nEPOCHS_PHASE2 = 12\nN_MODELS = 4   # ensemble de 4 modГЁles pour les labels faibles\n\nMODEL_NAMES = [\n    \"EfficientNetV2B3\",\n    \"DenseNet169\",\n    \"ResNet101V2\",\n    \"InceptionV3\"   # ajout d'Inception pour plus de diversitГ©\n]\n\ntf.keras.mixed_precision.set_global_policy(\"mixed_float16\")\n\n# -----------------------------\n# CHARGEMENT DES DONNГ‰ES\n# -----------------------------\ntrain_df = pd.read_csv(os.path.join(DATA_PATH, \"train\", \"_classesTR.csv\"))\nvalid_df = pd.read_csv(os.path.join(DATA_PATH, \"valid\", \"_classesv.csv\"))\ntest_df  = pd.read_csv(os.path.join(DATA_PATH, \"test\",  \"_classes.csv\"))\n\nK_COLS = [\"K0\",\"K1\",\"K2\"]\nN_COLS = [\"N0\",\"N1\",\"N2\"]\nP_COLS = [\"P0\",\"P1\"]\nALL_COLS = K_COLS + N_COLS + P_COLS\n\nfor df in [train_df, valid_df, test_df]:\n    for c in ALL_COLS:\n        df[c] = df[c].astype(np.float32)\n\nprint(f\"Train: {len(train_df)} | Valid: {len(valid_df)} | Test: {len(test_df)}\")\n\n# -----------------------------\n# CONSTRUCTION DES DATASETS (version simplifiГ©e, sans sample weights)\n# -----------------------------\nAUTOTUNE = tf.data.AUTOTUNE\n\ndef build_paths(df, folder):\n    return (DATA_PATH + f\"/{folder}/\" + df[\"filename\"].astype(str)).values\n\ntrain_paths = build_paths(train_df, \"train\")\nvalid_paths = build_paths(valid_df, \"valid\")\ntest_paths  = build_paths(test_df,  \"test\")\n\ndef decode_resize(path):\n    img = tf.io.read_file(path)\n    img = tf.image.decode_jpeg(img, channels=3)\n    img = tf.image.resize(img, [IMG_SIZE, IMG_SIZE], antialias=True)\n    return img\n\ndef preprocess(img):\n    return tf.keras.applications.efficientnet_v2.preprocess_input(img)\n\ndef make_ds(paths, labels_dict=None, training=False):\n    if labels_dict is None:\n        ds = tf.data.Dataset.from_tensor_slices(paths)\n        ds = ds.map(lambda p: preprocess(decode_resize(p)), num_parallel_calls=AUTOTUNE)\n    else:\n        y = {}\n        for k, v in labels_dict.items():\n            y[k] = tf.constant(v)\n        ds = tf.data.Dataset.from_tensor_slices((paths, y))\n        ds = ds.map(lambda p, y: (preprocess(decode_resize(p)), y), num_parallel_calls=AUTOTUNE)\n\n    if training:\n        ds = ds.shuffle(2048, reshuffle_each_iteration=True)\n    ds = ds.batch(BATCH_SIZE, drop_remainder=False).prefetch(AUTOTUNE)\n    return ds\n\n# PrГ©paration des labels (one-hot)\ndef prepare_labels(df):\n    k_onehot = pd.get_dummies(df[K_COLS].idxmax(axis=1)).values.astype(np.float32)\n    n_onehot = pd.get_dummies(df[N_COLS].idxmax(axis=1)).values.astype(np.float32)\n    p_onehot = pd.get_dummies(df[P_COLS].idxmax(axis=1)).values.astype(np.float32)\n    return {\"K\": k_onehot, \"N\": n_onehot, \"P\": p_onehot}\n\ntrain_labels = prepare_labels(train_df)\nvalid_labels = prepare_labels(valid_df)\n\ntrain_ds = make_ds(train_paths, train_labels, training=True)\nvalid_ds = make_ds(valid_paths, valid_labels, training=False)\ntest_ds  = make_ds(test_paths, labels_dict=None, training=False)\n\n# -----------------------------\n# MODГ€LE SPГ‰CIALISГ‰ (prГ©dit K, N, P)\n# -----------------------------\ndef build_backbone(name, input_shape):\n    if name == \"EfficientNetV2B3\":\n        return tf.keras.applications.EfficientNetV2B3(include_top=False, weights=\"imagenet\", input_shape=input_shape)\n    elif name == \"DenseNet169\":\n        return tf.keras.applications.DenseNet169(include_top=False, weights=\"imagenet\", input_shape=input_shape)\n    elif name == \"ResNet101V2\":\n        return tf.keras.applications.ResNet101V2(include_top=False, weights=\"imagenet\", input_shape=input_shape)\n    elif name == \"InceptionV3\":\n        return tf.keras.applications.InceptionV3(include_top=False, weights=\"imagenet\", input_shape=input_shape)\n    else:\n        raise ValueError(f\"ModГЁle inconnu: {name}\")\n\ndef build_model(backbone_name):\n    inp = tf.keras.Input(shape=(IMG_SIZE, IMG_SIZE, 3))\n    x = tf.keras.layers.RandomFlip(\"horizontal\")(inp)\n    x = tf.keras.layers.RandomRotation(0.1)(x)\n    x = tf.keras.layers.RandomZoom(0.15)(x)\n\n    base = build_backbone(backbone_name, (IMG_SIZE, IMG_SIZE, 3))\n    base.trainable = False\n    x = base(x, training=False)\n\n    x = tf.keras.layers.GlobalAveragePooling2D()(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(0.4)(x)\n    x = tf.keras.layers.Dense(512, activation=\"relu\")(x)\n    x = tf.keras.layers.BatchNormalization()(x)\n    x = tf.keras.layers.Dropout(0.3)(x)\n\n    outK = tf.keras.layers.Dense(3, activation=\"softmax\", dtype=\"float32\", name=\"K\")(x)\n    outN = tf.keras.layers.Dense(3, activation=\"softmax\", dtype=\"float32\", name=\"N\")(x)\n    outP = tf.keras.layers.Dense(2, activation=\"softmax\", dtype=\"float32\", name=\"P\")(x)\n\n    model = tf.keras.Model(inp, {\"K\": outK, \"N\": outN, \"P\": outP})\n    return model\n\n# -----------------------------\n# ENTRAГЋNEMENT D'UN MODГ€LE\n# -----------------------------\ndef train_one_model(model_idx, backbone_name):\n    print(f\"\\n{'='*60}\")\n    print(f\"рџЏ† MODГ€LE {model_idx+1}/{N_MODELS} : {backbone_name}\")\n    print(f\"{'='*60}\")\n\n    model_dir = os.path.join(SAVE_DIR, f\"model_{model_idx}\")\n    os.makedirs(model_dir, exist_ok=True)\n    best_path = os.path.join(model_dir, \"best.keras\")\n    last_path = os.path.join(model_dir, \"last.keras\")\n\n    if os.path.exists(last_path):\n        print(\"вЏ© Chargement du modГЁle existant...\")\n        return tf.keras.models.load_model(last_path)\n\n    model = build_model(backbone_name)\n\n    losses = {\n        \"K\": tf.keras.losses.CategoricalCrossentropy(label_smoothing=0.1),\n        \"N\": tf.keras.losses.CategoricalCrossentropy(label_smoothing=0.1),\n        \"P\": tf.keras.losses.CategoricalCrossentropy(label_smoothing=0.1),\n    }\n    metrics = {\n        \"K\": [tf.keras.metrics.CategoricalAccuracy(name=\"acc\")],\n        \"N\": [tf.keras.metrics.CategoricalAccuracy(name=\"acc\")],\n        \"P\": [tf.keras.metrics.CategoricalAccuracy(name=\"acc\")],\n    }\n\n    callbacks_list = [\n        callbacks.ModelCheckpoint(best_path, monitor=\"val_loss\", save_best_only=True, mode=\"min\", verbose=1),\n        callbacks.ModelCheckpoint(last_path, monitor=\"val_loss\", save_best_only=False, mode=\"min\", verbose=0),\n        callbacks.EarlyStopping(monitor=\"val_loss\", patience=5, restore_best_weights=True, verbose=1),\n        callbacks.ReduceLROnPlateau(monitor=\"val_loss\", factor=0.5, patience=2, min_lr=1e-7, verbose=1),\n        callbacks.TerminateOnNaN(),\n    ]\n\n    # Phase 1\n    print(\"\\nрџљЂ Phase 1\")\n    model.compile(optimizer=optimizers.Adam(3e-4), loss=losses, metrics=metrics)\n    model.fit(train_ds, validation_data=valid_ds, epochs=EPOCHS_PHASE1, callbacks=callbacks_list, verbose=1)\n\n    # Phase 2 (fine-tuning)\n    print(\"\\nрџ› пёЏ Phase 2\")\n    for layer in model.layers:\n        if layer.name.startswith((\"efficientnet\", \"densenet\", \"resnet\", \"inception\")):\n            layer.trainable = True\n            total = len(layer.layers)\n            freeze_until = int(total * 0.7)\n            for i, sub in enumerate(layer.layers):\n                sub.trainable = (i >= freeze_until)\n            break\n\n    model.compile(optimizer=optimizers.Adam(1e-5), loss=losses, metrics=metrics)\n    model.fit(train_ds, validation_data=valid_ds, epochs=EPOCHS_PHASE2, callbacks=callbacks_list, verbose=1)\n\n    if os.path.exists(best_path):\n        model = tf.keras.models.load_model(best_path)\n    return model\n\n# -----------------------------\n# ENTRAГЋNEMENT DES 4 MODГ€LES\n# -----------------------------\nmodels = []\nfor idx, name in enumerate(MODEL_NAMES[:N_MODELS]):\n    m = train_one_model(idx, name)\n    models.append(m)\n    tf.keras.backend.clear_session()\n    gc.collect()\n\n# -----------------------------\n# PRГ‰DICTION ENSEMBLE\n# -----------------------------\nprint(\"\\nрџ”® PrГ©diction avec l'ensemble...\")\ntest_ds = make_ds(test_paths, labels_dict=None, training=False)\n\nall_probs_K, all_probs_N, all_probs_P = [], [], []\nfor idx, model in enumerate(models):\n    print(f\"  ModГЁle {idx+1}\")\n    pred = model.predict(test_ds, verbose=1)\n    all_probs_K.append(pred[\"K\"])\n    all_probs_N.append(pred[\"N\"])\n    all_probs_P.append(pred[\"P\"])\n\navg_K = np.mean(all_probs_K, axis=0)\navg_N = np.mean(all_probs_N, axis=0)\navg_P = np.mean(all_probs_P, axis=0)\n\nK_idx = np.argmax(avg_K, axis=1)\nN_idx = np.argmax(avg_N, axis=1)\nP_idx = np.argmax(avg_P, axis=1)\n\ny_pred = np.zeros((len(test_df), 8), dtype=np.int32)\ny_pred[np.arange(len(test_df)), K_idx] = 1\ny_pred[np.arange(len(test_df)), 3 + N_idx] = 1\ny_pred[np.arange(len(test_df)), 6 + P_idx] = 1\n\n# -----------------------------\n# Г‰VALUATION\n# -----------------------------\ny_true = test_df[ALL_COLS].values.astype(np.int32)\nhamming = np.mean(y_true == y_pred)\nprint(\"\\n\" + \"=\"*60)\nprint(f\"рџЏ† HAMMING ACCURACY FINALE : {hamming:.4f} ({hamming*100:.2f}%)\")\nprint(\"=\"*60)\n\nprint(\"\\nAccuracy par label :\")\nfor i, col in enumerate(ALL_COLS):\n    acc = np.mean(y_true[:,i] == y_pred[:,i])\n    print(f\"  {col}: {acc:.4f}\")\n\n# Sauvegarde\nresults = {\"hamming_accuracy\": float(hamming), \"per_label_accuracy\": {}}\nfor i, col in enumerate(ALL_COLS):\n    results[\"per_label_accuracy\"][col] = float(np.mean(y_true[:,i] == y_pred[:,i]))\nwith open(os.path.join(SAVE_DIR, \"results.json\"), \"w\") as f:\n    json.dump(results, f, indent=2)\n\nout_df = test_df[[\"filename\"]].copy()\nfor i, col in enumerate(ALL_COLS):\n    out_df[col + \"_pred\"] = y_pred[:, i]\nout_df.to_csv(os.path.join(SAVE_DIR, \"test_predictions.csv\"), index=False)\nprint(f\"\\nвњ… RГ©sultats dans {SAVE_DIR}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-26T22:34:20.302449Z","iopub.execute_input":"2026-02-26T22:34:20.302708Z","iopub.status.idle":"2026-02-26T23:01:12.391913Z","shell.execute_reply.started":"2026-02-26T22:34:20.302684Z","shell.execute_reply":"2026-02-26T23:01:12.391306Z"}},"outputs":[{"name":"stderr","text":"2026-02-26 22:34:22.897035: E external/local_xla/xla/stream_executor/cuda/cuda_fft.cc:467] Unable to register cuFFT factory: Attempting to register factory for plugin cuFFT when one has already been registered\nWARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nE0000 00:00:1772145263.086498     