{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":14608299,"datasetId":9331094,"databundleVersionId":15444458}],"dockerImageVersionId":31287,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# ====================================================\n# train_npk_kaggle_reprise.py\n# Entraînement avec reprise automatique par modèle\n# Paramètres optimisés pour finir dans les 9h (≥90% visé)\n# ====================================================\n\nimport os, json, gc, time\nimport numpy as np\nimport pandas as pd\nimport tensorflow as tf\nfrom tensorflow.keras import layers, optimizers, callbacks\nfrom sklearn.metrics import accuracy_score, f1_score, precision_score, recall_score\nfrom sklearn.utils.class_weight import compute_class_weight\n\n# ====================================================\n# CONFIGURATION (à adapter si nécessaire)\n# ====================================================\nDATA_PATH = \"/kaggle/input/datasets/dhiaeddinesaadallah/prdiction-npk\"\nSAVE_DIR  = \"/kaggle/working/npk_models_v4\"   # nouveau dossier (pour éviter conflit avec anciens)\nos.makedirs(SAVE_DIR, exist_ok=True)\n\n# Paramètres optimisés\nIMG_SIZE = 299          # compromis précision/temps (224 possible mais moins bon)\nBATCH_SIZE = 12\nEPOCHS_PHASE1 = 8\nEPOCHS_PHASE2 = 8\nN_MODELS = 3            # on garde les 3 meilleurs\n\nlabels = ['K0','K1','K2','N0','N1','N2','P0','P1']\n\n# Mixed precision pour économiser la mémoire GPU\ntf.keras.mixed_precision.set_global_policy('mixed_float16')\n\n# ====================================================\n# CHARGEMENT DES DONNÉES\n# ====================================================\nprint(\"=\"*60)\nprint(\"📥 CHARGEMENT DES DONNÉES\")\nprint(\"=\"*60)\n\ntrain_df = pd.read_csv(os.path.join(DATA_PATH, \"train\", \"_classesTR.csv\"))\nvalid_df = pd.read_csv(os.path.join(DATA_PATH, \"valid\", \"_classesv.csv\"))\ntest_df  = pd.read_csv(os.path.join(DATA_PATH, \"test\", \"_classes.csv\"))\n\nfor df in [train_df, valid_df, test_df]:\n    for col in labels:\n        df[col] = df[col].astype(np.float32)\n\nprint(f\"Train: {len(train_df)} images\")\nprint(f\"Valid: {len(valid_df)} images\")\nprint(f\"Test: {len(test_df)} images\")\n\n# ====================================================\n# DATA AUGMENTATION\n# ====================================================\ndef get_augmentation():\n    return tf.keras.preprocessing.image.ImageDataGenerator(\n        preprocessing_function=tf.keras.applications.efficientnet.preprocess_input,\n        rotation_range=45,\n        width_shift_range=0.15,\n        height_shift_range=0.15,\n        shear_range=0.15,\n        zoom_range=0.25,\n        horizontal_flip=True,\n        brightness_range=[0.8, 1.2],\n        fill_mode='reflect'\n    )\n\nval_datagen = tf.keras.preprocessing.image.ImageDataGenerator(\n    preprocessing_function=tf.keras.applications.efficientnet.preprocess_input\n)\n\ndef create_generator(df, label, folder, augment=False):\n    gen = get_augmentation() if augment else val_datagen\n    return gen.flow_from_dataframe(\n        df,\n        directory=os.path.join(DATA_PATH, folder),\n        x_col='filename',\n        y_col=label,\n        target_size=(IMG_SIZE, IMG_SIZE),\n        batch_size=BATCH_SIZE,\n        class_mode='raw',\n        shuffle=augment,\n        seed=42\n    )\n\n# ====================================================\n# FABRIQUE DE MODÈLES (3 meilleurs)\n# ====================================================\ndef build_model(model_name):\n    if model_name == 'EfficientNetB5':\n        base = tf.keras.applications.EfficientNetB5(weights='imagenet', include_top=False, input_shape=(IMG_SIZE, IMG_SIZE, 3))\n    elif model_name == 'DenseNet201':\n        base = tf.keras.applications.DenseNet201(weights='imagenet', include_top=False, input_shape=(IMG_SIZE, IMG_SIZE, 3))\n    elif model_name == 'ResNet152V2':\n        base = tf.keras.applications.ResNet152V2(weights='imagenet', include_top=False, input_shape=(IMG_SIZE, IMG_SIZE, 3))\n    else:\n        raise ValueError(f\"Modèle inconnu : {model_name}\")\n    base.trainable = False\n    x = layers.GlobalAveragePooling2D()(base.output)\n    x = layers.BatchNormalization()(x)\n    x = layers.Dropout(0.5)(x)\n    x = layers.Dense(512, activation='relu')(x)\n    x = layers.BatchNormalization()(x)\n    x = layers.Dropout(0.4)(x)\n    output = layers.Dense(1, activation='sigmoid')(x)\n    return tf.keras.Model(base.input, output), base\n\n# ====================================================\n# FONCTIONS UTILITAIRES\n# ====================================================\ndef get_class_weights(y_train):\n    weights = compute_class_weight('balanced', classes=np.array([0,1]), y=y_train)\n    return {0: weights[0], 1: weights[1]}\n\ndef find_best_threshold(y_true, y_prob):\n    best_t, best_f1 = 0.5, 0\n    for t in np.arange(0.1, 0.9, 0.02):\n        y_pred = (y_prob > t).astype(int)\n        f1 = f1_score(y_true, y_pred, zero_division=0)\n        if f1 > best_f1:\n            best_f1 = f1\n            best_t = t\n    return best_t\n\ndef get_model_index(model_name):\n    # Ordre des modèles (doit correspondre à la liste dans train_label)\n    order = ['EfficientNetB5', 'DenseNet201', 'ResNet152V2']\n    return order.index(model_name) if model_name in order else -1\n\n# ====================================================\n# ENTRAÎNEMENT D'UN MODÈLE\n# ====================================================\ndef train_single_model(train_df, valid_df, label, model_name):\n    print(f\"\\n🎯 Entraînement {model_name} pour {label}\")\n    model, base = build_model(model_name)\n    y_train = train_df[label].astype(int).values\n    class_weight = get_class_weights(y_train)\n    print(f\"  📊 Poids: classe0={class_weight[0]:.2f}, classe1={class_weight[1]:.2f}\")\n\n    train_gen = create_generator(train_df, label, 'train', augment=True)\n    valid_gen = create_generator(valid_df, label, 'valid', augment=False)\n\n    # Phase 1\n    print(\"  Phase 1: Transfer Learning...\")\n    model.compile(optimizer=optimizers.Adam(3e-4), loss='binary_crossentropy',\n                  metrics=[tf.keras.metrics.AUC(name='auc')])\n    model.fit(train_gen, validation_data=valid_gen, epochs=EPOCHS_PHASE1,\n              class_weight=class_weight,\n              callbacks=[callbacks.EarlyStopping(monitor='val_auc', patience=2,\n                                                  restore_best_weights=True, mode='max')],\n              verbose=1)\n\n    # Phase 2\n    print(\"  Phase 2: Fine-tuning...\")\n    base.trainable = True\n    for layer in base.layers[:-60]:\n        layer.trainable = False\n    model.compile(optimizer=optimizers.Adam(8e-6), loss='binary_crossentropy',\n                  metrics=[tf.keras.metrics.AUC(name='auc')])\n    model.fit(train_gen, validation_data=valid_gen, epochs=EPOCHS_PHASE2,\n              class_weight=class_weight,\n              callbacks=[callbacks.EarlyStopping(monitor='val_auc', patience=2,\n                                                  restore_best_weights=True, mode='max')],\n              verbose=1)\n\n    # Évaluation sur validation (pour seuil)\n    valid_gen_pred = val_datagen.flow_from_dataframe(valid_df,\n                                                      directory=os.path.join(DATA_PATH, 'valid'),\n                                                      x_col='filename', y_col=None,\n                                                      target_size=(IMG_SIZE, IMG_SIZE),\n                                                      batch_size=BATCH_SIZE, shuffle=False,\n                                                      class_mode=None, seed=42)\n    val_probs = model.predict(valid_gen_pred, verbose=0).ravel()\n    best_t = find_best_threshold(valid_df[label].values, val_probs)\n    val_pred = (val_probs > best_t).astype(int)\n    val_f1 = f1_score(valid_df[label].values, val_pred, zero_division=0)\n    val_acc = accuracy_score(valid_df[label].values, val_pred)\n    print(f\"  ✅ {model_name} - Seuil: {best_t:.3f}, F1: {val_f1:.4f}, Acc: {val_acc:.4f}\")\n    return model, best_t, val_f1\n\n# ====================================================\n# ENTRAÎNEMENT POUR UN LABEL (avec reprise par modèle)\n# ====================================================\ndef train_label(train_df, valid_df, label):\n    print(f\"\\n{'='*60}\\n🏆 ENTRAINEMENT POUR {label}\\n{'='*60}\")\n    model_names = ['EfficientNetB5', 'DenseNet201', 'ResNet152V2']\n    models = []\n    thresholds = []\n    scores = []\n\n    # Créer le dossier du label\n    label_dir = os.path.join(SAVE_DIR, label)\n    os.makedirs(label_dir, exist_ok=True)\n\n    for idx, name in enumerate(model_names):\n        model_path = os.path.join(label_dir, f'model_{idx}.keras')\n        seuil_path = os.path.join(label_dir, f'threshold_{idx}.json')\n\n        # Si le modèle existe déjà, on le charge et on récupère son seuil\n        if os.path.exists(model_path) and os.path.exists(seuil_path):\n            print(f\"  ⏩ Modèle {name} déjà existant, chargement...\")\n            model = tf.keras.models.load_model(model_path)\n            with open(seuil_path, 'r') as f:\n                data = json.load(f)\n                t = data['threshold']\n                s = data['f1']\n            # Recalcul éventuel (optionnel, on peut juste utiliser les valeurs sauvegardées)\n            # Pour plus de sécurité, on pourrait recalculer, mais on gagne du temps.\n        else:\n            # Entraîner le modèle\n            model, t, s = train_single_model(train_df, valid_df, label, name)\n            # Sauvegarder modèle et seuil\n            model.save(model_path)\n            with open(seuil_path, 'w') as f:\n                json.dump({'threshold': t, 'f1': s}, f)\n\n        models.append(model)\n        thresholds.append(t)\n        scores.append(s)\n\n        # Nettoyage mémoire\n        tf.keras.backend.clear_session()\n        gc.collect()\n\n    # Seuil pondéré final\n    weights = np.array(scores) / np.sum(scores)\n    final_threshold = np.average(thresholds, weights=weights)\n    print(f\"\\n✅ {label} - Seuil final: {final_threshold:.3f}\")\n    return final_threshold\n\n# ====================================================\n# EXÉCUTION PRINCIPALE\n# ====================================================\nif __name__ == \"__main__\":\n    print(\"\\n🚀 DÉBUT DE L'ENTRAÎNEMENT (REPRISE AUTOMATIQUE)\")\n    start_time = time.time()\n    all_thresholds = {}\n\n    for label in labels:\n        seuil_file = os.path.join(SAVE_DIR, f\"seuil_{label}.json\")\n        if os.path.exists(seuil_file):\n            with open(seuil_file, 'r') as f:\n                all_thresholds[label] = json.load(f)['seuil']\n            print(f\"✅ {label} déjà terminé, seuil = {all_thresholds[label]:.3f}\")\n        else:\n            print(f\"\\n--- Début de l'entraînement pour {label} ---\")\n            seuil = train_label(train_df, valid_df, label)\n            all_thresholds[label] = seuil\n            with open(seuil_file, 'w') as f:\n                json.dump({'seuil': seuil}, f)\n            print(f\"--- Fin de l'entraînement pour {label} ---\")\n\n    print(\"\\n\" + \"=\"*60)\n    print(\"🎉 TOUS LES LABELS ONT ÉTÉ TRAITÉS !\")\n    print(\"=\"*60)\n\n    # ====================================================\n    # PRÉDICTION SUR LE TEST\n    # ====================================================\n    print(\"\\n🔮 Prédiction sur le test...\")\n    test_gen = val_datagen.flow_from_dataframe(\n        test_df,\n        directory=os.path.join(DATA_PATH, 'test'),\n        x_col='filename',\n        y_col=None,\n        target_size=(IMG_SIZE, IMG_SIZE),\n        batch_size=BATCH_SIZE,\n        shuffle=False,\n        class_mode=None,\n        seed=42\n    )\n\n    final_preds = np.zeros((len(test_df), len(labels)))\n    for i, label in enumerate(labels):\n        print(f\"  {label}...\")\n        preds_list = []\n        label_dir = os.path.join(SAVE_DIR, label)\n        # Compter les modèles (normalement 3)\n        for j in range(N_MODELS):\n            model_path = os.path.join(label_dir, f'model_{j}.keras')\n            if not os.path.exists(model_path):\n                continue\n            model = tf.keras.models.load_model(model_path)\n            preds = model.predict(test_gen, verbose=0).ravel()\n            preds_list.append(preds)\n        final_preds[:, i] = np.mean(preds_list, axis=0)\n\n    thresholds = [all_thresholds[label] for label in labels]\n    y_pred = (final_preds > np.array(thresholds)).astype(int)\n\n    # Post‑traitement : un seul niveau par nutriment\n    for i in range(len(test_df)):\n        # K (0,1,2)\n        cols = [0,1,2]\n        if y_pred[i, cols].sum() > 1:\n            probs = final_preds[i, cols]\n            y_pred[i, cols] = 0\n            y_pred[i, cols[np.argmax(probs)]] = 1\n        elif y_pred[i, cols].sum() == 0:\n            probs = final_preds[i, cols]\n            y_pred[i, cols[np.argmax(probs)]] = 1\n\n        # N (3,4,5)\n        cols = [3,4,5]\n        if y_pred[i, cols].sum() > 1:\n            probs = final_preds[i, cols]\n            y_pred[i, cols] = 0\n            y_pred[i, cols[np.argmax(probs)]] = 1\n        elif y_pred[i, cols].sum() == 0:\n            probs = final_preds[i, cols]\n            y_pred[i, cols[np.argmax(probs)]] = 1\n\n        # P (6,7)\n        cols = [6,7]\n        if y_pred[i, cols].sum() > 1:\n            probs = final_preds[i, cols]\n            y_pred[i, cols] = 0\n            y_pred[i, cols[np.argmax(probs)]] = 1\n        elif y_pred[i, cols].sum() == 0:\n            probs = final_preds[i, cols]\n            y_pred[i, cols[np.argmax(probs)]] = 1\n\n    y_true = test_df[labels].values\n    hamming = np.mean(y_true == y_pred)\n\n    print(\"\\n\" + \"=\"*60)\n    print(f\"🏆 HAMMING ACCURACY FINALE : {hamming:.4f} ({hamming*100:.2f}%)\")\n    print(\"=\"*60)\n\n    # Sauvegarde des résultats\n    results = {\n        'hamming_accuracy': float(hamming),\n        'thresholds': {label: float(all_thresholds[label]) for label in labels},\n        'per_label_accuracy': {label: float(np.mean(y_true[:,i] == y_pred[:,i])) for i, label in enumerate(labels)}\n    }\n    with open(os.path.join(SAVE_DIR, 'results.json'), 'w') as f:\n        json.dump(results, f, indent=2)\n\n    # Sauvegarde des prédictions\n    pred_df = test_df[['filename']].copy()\n    for i, lbl in enumerate(labels):\n        pred_df[f'{lbl}_pred'] = y_pred[:, i]\n        pred_df[f'{lbl}_prob'] = final_preds[:, i]\n    pred_df.to_csv(os.path.join(SAVE_DIR, 'test_predictions.csv'), index=False)\n\n    print(f\"\\n✅ Résultats sauvegardés dans {SAVE_DIR}\")\n    print(f\"⏱️  Temps total : {(time.time()-start_time)/3600:.2f} heures\")","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-02-25T20:25:51.289396Z","iopub.execute_input":"2026-02-25T20:25:51.289841Z"}},"outputs":[{"name":"stderr","text":"2026-02-25 20:25:53.535594: E external/local_xla/xla/stream_executor/cuda/cuda_fft.cc:467] Unable to register cuFFT factory: Attempting to register factory for plugin cuFFT when one has already been registered\nWARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nE0000 00:00:1772051153.741840      55 cuda_dnn.cc:8579] Unable to register cuDNN factory: Attempting to register factory for plugin cuDNN when one has already been registered\nE0000 00:00:1772051153.803409      55 cuda_blas.cc:1407]